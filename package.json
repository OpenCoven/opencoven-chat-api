    "build:index": "bun scripts/build-vector-index.ts",
    "deploy": "vercel"
  },
  "dependencies": {
    "@create-markdown/core": "^2.0.0",
    "@create-markdown/react": "^2.0.0",
    "@upstash/ratelimit": "^2.0.8",
