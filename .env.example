# =============================================================================
# Salem / OpenCoven Chat API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# UPSTASH VECTOR (required)
# Used for semantic search / vector embeddings storage.
# -----------------------------------------------------------------------------
UPSTASH_VECTOR_REST_URL=your_upstash_vector_rest_url
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_rest_token

# -----------------------------------------------------------------------------
# UPSTASH REDIS (required for rate limiting and BM25 keyword index storage)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token

# -----------------------------------------------------------------------------
# OPENAI (required)
# Used for streaming chat completions and primary embedding generation.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key

# Default chat model for responses
# Options: gpt-5-nano, gpt-5-mini, gpt-5, gpt-5.1, gpt-5.2
DEFAULT_CHAT_MODEL=gpt-5.5

# -----------------------------------------------------------------------------
# EMBEDDINGS (optional)
# OpenAI embeddings are used when OPENAI_API_KEY is available. Gemini can be used
# as a fallback or forced with EMBEDDINGS_PROVIDER=gemini.
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
EMBEDDINGS_PROVIDER=auto

# -----------------------------------------------------------------------------
# COHERE (optional)
# Used for cross-encoder reranking when hybrid search is enabled.
# -----------------------------------------------------------------------------
COHERE_API_KEY=your_cohere_api_key

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------

# Enable hybrid search: semantic + BM25 keyword search + optional reranking.
# When false, Salem uses semantic-only retrieval.
ENABLE_HYBRID_SEARCH=true

# -----------------------------------------------------------------------------
# GITHUB WEBHOOK (optional)
# Used for automatic documentation re-indexing on push to the docs main branch.
# Generate secret with: openssl rand -hex 32
# -----------------------------------------------------------------------------
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# -----------------------------------------------------------------------------
# SCHEDULED REINDEX (optional but recommended)
# Used by QStash or another scheduler to re-index docs as a safety net for
# missed webhooks and docs deploy timing races.
# Generate secret with: openssl rand -hex 32
# -----------------------------------------------------------------------------
REINDEX_SECRET=your_reindex_secret

# -----------------------------------------------------------------------------
# CORS (optional)
# Comma-separated list of allowed origins for cross-origin requests.
# Defaults to https://docs.opencoven.ai, https://opencoven.ai, and
# https://salem.opencoven.ai.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=https://docs.opencoven.ai,https://opencoven.ai,https://salem.opencoven.ai

# -----------------------------------------------------------------------------
# PUBLIC BASE URL (optional)
# Absolute origin of this deployment, used only to build Open Graph / Twitter
# card image URLs in the page metadata. Not used by the chat API itself.
# Defaults to https://salem.opencoven.ai.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://salem.opencoven.ai
